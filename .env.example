# ── Riconoscimento foto (server-side, NON esposta al client) ──
NUXT_ANTHROPIC_API_KEY=sk-ant-...

# ── Firebase (chiavi pubbliche lato client) ──
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=

# ── Base URL delle API (per l'app nativa che punta al deploy) ──
NUXT_PUBLIC_API_BASE=

# ── Withings (opzionale) ──
NUXT_WITHINGS_CLIENT_ID=
NUXT_WITHINGS_CLIENT_SECRET=
NUXT_PUBLIC_WITHINGS_REDIRECT_URI=http://localhost:3000/api/withings/callback

# Nota: lasciando Firebase vuoto l'app parte in "modalità demo" (dati solo locali).
